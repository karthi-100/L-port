# ========== APPLICATION SETTINGS ==========
DEBUG=False
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ========== RAZORPAY CONFIGURATION ==========
# Get these from your Razorpay Dashboard: https://dashboard.razorpay.com
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ========== SMTP EMAIL CONFIGURATION ==========
# For Gmail: Use App Password (not regular password)
# Enable 2FA and generate App Password: https://myaccount.google.com/apppasswords
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_NAME=L-Port Support
SUPPORT_EMAIL=support@l-port.com

# ========== CORS CONFIGURATION ==========
# Frontend URL(s) for CORS (comma-separated for multiple)
FRONTEND_URL=http://localhost:5173,http://localhost:4744
BACKEND_URL=http://localhost:8000

# ========== DATABASE (OPTIONAL FOR FUTURE) ==========
# DATABASE_URL=postgresql://user:password@localhost/dbname
